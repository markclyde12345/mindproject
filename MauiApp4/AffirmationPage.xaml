<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.AffirmationPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F3E8">

    <Grid Padding="25">

        <!-- Close -->
        <Label Text="✕"
               FontSize="20"
               TextColor="#333"
               HorizontalOptions="Start"
               VerticalOptions="Start">

            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseTapped"/>
            </Label.GestureRecognizers>
        </Label>

        <!-- Main Card -->
        <Frame x:Name="card"
               BackgroundColor="White"
               CornerRadius="28"
               Padding="30"
               HasShadow="False"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               WidthRequest="300">

            <VerticalStackLayout Spacing="20"
                                 HorizontalOptions="Center">

                <!-- Calm icon -->
                <Label Text="☁"
                       FontSize="40"
                       HorizontalOptions="Center"
                       TextColor="#7C8A9A"/>

                <!-- Affirmation Text -->
                <Label x:Name="affirmationLabel"
                       Text="You are enough."
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#2D2D2D"
                       HorizontalTextAlignment="Center"/>

                <!-- Sub text -->
                <Label Text="Take a moment to feel this."
                       FontSize="14"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>

        </Frame>

        <!-- Next Button -->
        <Button Text="Next"
                VerticalOptions="End"
                BackgroundColor="#2F3E46"
                TextColor="White"
                CornerRadius="25"
                HeightRequest="55"
                Clicked="OnNextClicked"/>

    </Grid>

</ContentPage>