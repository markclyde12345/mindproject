<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="project.NavigationBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border BackgroundColor="White"
            Padding="10"
            HeightRequest="70"
            VerticalOptions="End">

        <Grid ColumnDefinitions="*,*,*,*">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <Image Source="home.png" HeightRequest="28"/>
                <Label Text="Home" FontSize="12" TextColor="Black"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Check-in -->
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Image Source="checkin.png" HeightRequest="28"/>
                <Label Text="Check-in" FontSize="12" TextColor="Black"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCheckInTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Progress -->
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <Image Source="progress.png" HeightRequest="28"/>
                <Label Text="Progress" FontSize="12" TextColor="Black"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProgressTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Profile -->
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                <Image Source="profile.png" HeightRequest="28"/>
                <Label Text="Profile" FontSize="12" TextColor="Black"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>
    </Border>
</ContentView>