<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.SadValidationPage"
             BackgroundColor="#F5FAF5">

	<ScrollView>
		<VerticalStackLayout Padding="24,20,24,40" Spacing="0" BackgroundColor="#F5FAF5">

			<!-- Header Row -->
			<Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="0">
					<Label Text="COM" TextColor="#1A1A1A" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Text="PANION" TextColor="#1560BD" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
				</HorizontalStackLayout>
			</Grid>

			<!-- Progress Bar -->
			<ProgressBar x:Name="ProgressBar"
                         Progress="0.7"
                         HeightRequest="8"
                         BackgroundColor="BLACK"
                         ProgressColor="#1560BD"
                         Margin="0,0,0,6"/>
			<Label Text="Activity Check-In"
                   HorizontalOptions="Center"
                   TextColor="#888888"
                   FontSize="13"
                   Margin="0,0,0,24"/>

			<!-- Mood Icon -->
			<Frame BackgroundColor="#D6E8F5"
                   CornerRadius="45"
                   WidthRequest="90"
                   HeightRequest="90"
                   Padding="0"
                   HorizontalOptions="Center"
                   HasShadow="False"
                   Margin="0,0,0,12">
				<Label x:Name="MoodEmoji"
                       Text="😢"
                       FontSize="38"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- Mood Title -->
			<Label x:Name="MoodTitle"
                   Text="You're Feeling Sad"
                   TextColor="#1A1A1A"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>

			<Label Text="Your feelings are valid. Taking a moment to express them can help lighten the weight you carry."
                   FontSize="14"
                   TextColor="#666666"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,24"/>

			<!-- Self-Compassion Tip Card -->
			<Frame CornerRadius="14"
                   BackgroundColor="#D6E8F5"
                   BorderColor="#A0C4E0"
                   HasShadow="False"
                   Padding="16,14"
                   Margin="0,0,0,24">
				<HorizontalStackLayout Spacing="12">
					<Label FontSize="22" VerticalOptions="Start" Margin="0,2,0,0"/>
					<Label VerticalOptions="Center" LineBreakMode="WordWrap" MaximumWidthRequest="300">
						<Label.FormattedText>
							<FormattedString>
								<Span Text="Self-Compassion Activity: "
                                      FontAttributes="Bold"
                                      TextColor="#1A1A1A"
                                      FontSize="14"/>
								<Span Text="Be kind to yourself. Write it out and let it go gently."
                                      TextColor="#555555"
                                      FontSize="14"/>
							</FormattedString>
						</Label.FormattedText>
					</Label>
				</HorizontalStackLayout>
			</Frame>

			<!-- Instruction -->
			<Label Text="Sit with your feelings for a moment, then share:"
                   TextColor="#444444"
                   FontSize="15"
                   FontAttributes="Bold"
                   Margin="0,0,0,16"/>

			<!-- WHAT MADE YOU FEEL SAD TODAY -->
			<Label Text="WHAT MADE YOU FEEL SAD TODAY?"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>
			<Frame CornerRadius="12"
                   BackgroundColor="#d8f9ff"
                   BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
				<Entry x:Name="CauseEntry"
                       Placeholder="e.g. a memory, bad news, loneliness..."
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- SOMETHING YOU ARE GRATEFUL FOR -->
			<Label Text="SOMETHING YOU ARE GRATEFUL FOR"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>
			<Frame CornerRadius="12"
                   BackgroundColor="#d8f9ff"
                   BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
				<Entry x:Name="GratitudeEntry"
                       Placeholder="e.g. a friend, a safe place, music..."
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- A KIND WORD TO YOURSELF -->
			<Label Text="A KIND WORD TO YOURSELF"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>
			<Frame CornerRadius="12"
                   BackgroundColor="#d8f9ff"
                   BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,28">
				<Entry x:Name="KindnessEntry"
                       Placeholder="e.g. I am doing my best, I matter..."
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- Submit Button -->
			<Button Text="Submit Activity"
                    Clicked="OnSubmitActivityClicked"
                    BackgroundColor="#1560BD"
                    TextColor="White"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="17"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>
