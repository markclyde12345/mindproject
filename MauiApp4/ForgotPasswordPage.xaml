<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.ForgotPasswordPage"
             BackgroundColor="#F5FAF5">

    <ScrollView>
        <VerticalStackLayout Padding="30,40,30,40"
                             Spacing="0"
                             BackgroundColor="#F5FAF5">

            <!-- Back Button -->
            <Label Text="← Back"
                   TextColor="#3A8A3A"
                   FontSize="15"
                   FontAttributes="Bold"
                   Margin="0,0,0,30">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Label.GestureRecognizers>
            </Label>

            <!-- App Name -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,0,0,4">
                <Label Text="Mind" TextColor="#1A1A1A" FontSize="28" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Text="Bloom" TextColor="#3A8A3A" FontSize="28" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Text="Mental Wellness Monitoring"
                   TextColor="#888888"
                   FontSize="14"
                   HorizontalOptions="Center"
                   Margin="0,0,0,30"/>

            <!-- Page Heading -->
            <Label Text="Reset Your Password"
                   TextColor="#1A1A1A"
                   FontSize="26"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <Label Text="Enter your email and we'll send you a reset link."
                   TextColor="#888888"
                   FontSize="14"
                   Margin="0,0,0,28"/>

            <!-- Email Info Card -->
            <Frame CornerRadius="14"
                   BackgroundColor="#EAF5EA"
                   BorderColor="#C2DFC2"
                   HasShadow="False"
                   Padding="16,14"
                   Margin="0,0,0,24">
                <HorizontalStackLayout Spacing="12">
                    <Label Text="📧" FontSize="22" VerticalOptions="Start" Margin="0,2,0,0"/>
                    <Label VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="How it works: "
                                      FontAttributes="Bold"
                                      TextColor="#1A1A1A"
                                      FontSize="14"/>
                                <Span Text="We'll send a secure reset link to your Gmail or email inbox. Click it to set a new password."
                                      TextColor="#444444"
                                      FontSize="14"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>
            </Frame>

            <!-- EMAIL Label -->
            <Label Text="EMAIL"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <!-- Email Entry -->
            <Frame CornerRadius="12"
                   BackgroundColor="#EAF5EA"
                   BorderColor="#C2DFC2"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,24">
                <Entry x:Name="EmailEntry"
                       Placeholder="your@email.com"
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       Keyboard="Email"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- Send Reset Link Button -->
            <Button Text="Send Reset Link"
                    Clicked="OnSendOtpTapped"
                    BackgroundColor="#3A8A3A"
                    TextColor="White"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="17"
                    Margin="0,0,0,16"/>

            <!-- Message Label -->
            <Label x:Name="MessageLabel"
                   HorizontalOptions="Center"
                   FontSize="14"
                   Margin="0,0,0,20"/>

            <!-- Hidden sections — kept to avoid code-behind errors -->
            <VerticalStackLayout x:Name="EmailSection"  IsVisible="False"/>
            <VerticalStackLayout x:Name="OtpSection"    IsVisible="False">
                <Entry x:Name="OtpEntry"/>
            </VerticalStackLayout>
            <VerticalStackLayout x:Name="ResetPasswordSection" IsVisible="False">
                <Entry x:Name="NewPasswordEntry"/>
                <Entry x:Name="ReEnterPasswordEntry"/>
            </VerticalStackLayout>

            <!-- Back to Sign In -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Remember your password?"
                       TextColor="#666666"
                       FontSize="14"/>
                <Label Text="Sign In"
                       TextColor="#3A8A3A"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
