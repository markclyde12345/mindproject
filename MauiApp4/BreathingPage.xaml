<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.BreathingPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#08111F">

    <Grid>

        <!-- Gradient feel layers -->
        <BoxView Color="#08111F"/>

        <BoxView Opacity="0.25"
                 VerticalOptions="Start"
                 HeightRequest="350"
                 Color="#1C3D73"/>

        <!-- Floating Stars -->
        <Label x:Name="star1" Text="✦" TextColor="#88FFFFFF"
               FontSize="16" Margin="40,120,0,0"
               HorizontalOptions="Start"
               VerticalOptions="Start"/>

        <Label x:Name="star2" Text="✦" TextColor="#55FFFFFF"
               FontSize="12" Margin="280,180,0,0"
               HorizontalOptions="Start"
               VerticalOptions="Start"/>

        <Label x:Name="star3" Text="✦" TextColor="#66FFFFFF"
               FontSize="14" Margin="320,420,0,0"
               HorizontalOptions="Start"
               VerticalOptions="Start"/>

        <!-- Close -->
        <Border Margin="18,24,0,0"
                WidthRequest="42"
                HeightRequest="42"
                BackgroundColor="#22FFFFFF"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 21"
                HorizontalOptions="Start"
                VerticalOptions="Start">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseTapped"/>
            </Border.GestureRecognizers>

            <Label Text="✕"
                   TextColor="White"
                   FontSize="18"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Border>

        <!-- Center Content -->
        <VerticalStackLayout Spacing="24"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <Label Text="Breathe"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>

            <Label Text="Slowly follow the rhythm"
                   FontSize="14"
                   TextColor="#AFC3DD"
                   HorizontalOptions="Center"/>

            <!-- Orb -->
            <Grid>

                <!-- Glow -->
                <Border x:Name="glow"
                        WidthRequest="290"
                        HeightRequest="290"
                        BackgroundColor="#2268D8FF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 145"/>

                <!-- Main Orb -->
                <Border x:Name="orb"
                        WidthRequest="220"
                        HeightRequest="220"
                        BackgroundColor="#6FD6FF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 110"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="5">

                        <Label x:Name="phaseLabel"
                               Text="Ready"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>

                        <Label x:Name="countLabel"
                               Text="Tap Start"
                               FontSize="14"
                               TextColor="#EAF9FF"
                               HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                </Border>

            </Grid>

        </VerticalStackLayout>

        <!-- Bottom Button -->
        <Button x:Name="startButton"
                Text="Begin Session"
                Margin="24,0,24,34"
                HeightRequest="58"
                CornerRadius="29"
                BackgroundColor="White"
                TextColor="#08111F"
                FontSize="18"
                VerticalOptions="End"
                Clicked="OnStartClicked"/>

    </Grid>
</ContentPage>