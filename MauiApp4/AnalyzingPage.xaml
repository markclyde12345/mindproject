<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.AnalyzingPage"
             BackgroundColor="#E8E3D9">

    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="20">

        <Frame HeightRequest="120"
               WidthRequest="120"
               CornerRadius="60"
               BackgroundColor="#7FB6D9"
               HorizontalOptions="Center">

            <Label Text="🧠"
                   FontSize="50"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Frame>

        <Label Text="Analyzing your responses..."
               FontSize="18"
               HorizontalTextAlignment="Center"/>

        <Label Text="Determining your emotional state"
               FontSize="14"
               HorizontalTextAlignment="Center"
               TextColor="Gray"/>

        <ActivityIndicator
            IsRunning="True"
            Color="#7FB6D9"
            HeightRequest="40"
            WidthRequest="40"/>

    </VerticalStackLayout>

</ContentPage>