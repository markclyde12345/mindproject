<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.MoodResultPage"
             Title="Your Result">

    <VerticalStackLayout Padding="32" Spacing="24" VerticalOptions="Center">

        <Label Text="Check-In Complete"
               FontSize="22"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <Label Text="Your total score"
               FontSize="14"
               TextColor="Gray"
               HorizontalTextAlignment="Center" />

        <!-- Big score display -->
        <Frame CornerRadius="16"
               BackgroundColor="#F5F5F5"
               Padding="24"
               HorizontalOptions="Center">
            <Label x:Name="ScoreLabel"
                   FontSize="48"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Frame>

        <Label x:Name="MoodLabel"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

        <Label x:Name="DescriptionLabel"
               FontSize="16"
               TextColor="Gray"
               HorizontalTextAlignment="Center"
               LineBreakMode="WordWrap" />

        <Button Text="Done"
                Clicked="OnDoneClicked"
                CornerRadius="12"
                Margin="0,16,0,0" />

    </VerticalStackLayout>

</ContentPage>