<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="project.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:project"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">




    <ShellContent Route="MainPage" ContentTemplate="{DataTemplate pages:MainPage}" />
    <ShellContent Route="HomePage" ContentTemplate="{DataTemplate pages:HomePage}" />
    <ShellContent Route="MoodCheckInPage" ContentTemplate="{DataTemplate pages:MoodCheckInPage}" />
    <ShellContent Route="ProgressPage" ContentTemplate="{DataTemplate pages:ProgressReportPage}" />
    <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate pages:ProfilePage}" />


</Shell>

