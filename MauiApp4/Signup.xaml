<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.Signup"
             BackgroundColor="#F5FAF5">

    <ScrollView>
        <VerticalStackLayout Padding="30,40,30,40"
                             Spacing="0"
                             BackgroundColor="#F5FAF5">

            

            <!-- Page Heading -->
            <Label Text="Create Account"
                   TextColor="#1A1A1A"
                   FontSize="26"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <Label Text="Start your wellness journey today."
                   TextColor="#888888"
                   FontSize="14"
                   Margin="0,0,0,24"/>

            <!-- FIRST NAME -->
            <Label Text="FIRST NAME"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <Frame CornerRadius="12"
                    BackgroundColor="#d8f9ff"
                    BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
                <Entry x:Name="UsernameEntry"
                       Placeholder="First name"
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       Keyboard="Text"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- LAST NAME -->
            <Label Text="LAST NAME"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <Frame CornerRadius="12"
                    BackgroundColor="#d8f9ff"
                     BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
                <Entry x:Name="LastNameEntry"
                       Placeholder="Last name"
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       Keyboard="Text"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- EMAIL -->
            <Label Text="EMAIL"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <Frame CornerRadius="12"
                   BackgroundColor="#d8f9ff"
                   BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
                <Entry x:Name="EmailEntry"
                       Placeholder="your@email.com"
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       Keyboard="Email"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- PASSWORD -->
            <Label Text="PASSWORD"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <Frame CornerRadius="12"
                    BackgroundColor="#d8f9ff"
                    BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Enter password"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       IsPassword="True"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- CONFIRM PASSWORD -->
            <Label Text="CONFIRM PASSWORD"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>

            <Frame CornerRadius="12"
                    BackgroundColor="#d8f9ff"
                    BorderColor="#1560BD"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,24">
                <Entry x:Name="ConfirmPasswordEntry"
                       Placeholder="Re-enter password"
                       PlaceholderColor="#AAAAAA"
                       TextColor="#1A1A1A"
                       IsPassword="True"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- Sign Up Button -->
            <Button Text="Sign Up"
                    Clicked="OnSignUpClicked"
                    BackgroundColor="#1560BD"
                    TextColor="White"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="17"
                    Margin="0,0,0,16"/>

            <!-- Error Message -->
            <Label x:Name="MessageLabel"
                   TextColor="#EF4444"
                   HorizontalOptions="Center"
                   FontSize="14"
                   Margin="0,0,0,20"/>

            <!-- Already have an account -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Already have an account?"
                       TextColor="#666666"
                       FontSize="14"/>
                <Label Text="Sign In"
                       TextColor="#1560BD"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignInTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
