<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.CompletionPage"
             BackgroundColor="#d8f9ff"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="24"
                             Padding="40">

            <!-- Animated Circle Icon -->
            <Frame x:Name="CompletionIcon"
                   BackgroundColor="#1560BD"
                   CornerRadius="60"
                   WidthRequest="120"
                   HeightRequest="120"
                   Padding="0"
                   HorizontalOptions="Center"
                   HasShadow="False">
                <Label Text="😊"
                       FontSize="52"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- Completion Title -->
            <Label x:Name="CompletionText"
                   Text="Checking in complete"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A"
                   HorizontalOptions="Center"
                   Opacity="0"/>

            <!-- Completion Subtitle -->
            <Label x:Name="CompletionSubText"
                   Text="You're taking care of yourself! 💚"
                   FontSize="15"
                   TextColor="#555555"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center"
                   Opacity="0"/>

        </VerticalStackLayout>
    </Grid>

</ContentPage>
