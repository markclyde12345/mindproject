<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.AnxiousValidationPage"
             BackgroundColor="#F5FAF5">

	<ScrollView>
		<VerticalStackLayout Padding="24,50,24,40" Spacing="0" BackgroundColor="#F5FAF5">

			<!-- Header Row -->
			<Grid Margin="0,0,0,16">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<Label Grid.Column="0"
                       Text="← Back"
                       TextColor="#3A8A3A"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
					<Label.GestureRecognizers>
						<TapGestureRecognizer Tapped="OnBackTapped"/>
					</Label.GestureRecognizers>
				</Label>

				<HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="0">
					<Label Text="Mind" TextColor="#1A1A1A" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
					<Label Text="Bloom" TextColor="#3A8A3A" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
				</HorizontalStackLayout>
			</Grid>

			<!-- Progress Bar -->
			<ProgressBar x:Name="ProgressBar"
                         Progress="0.7"
                         HeightRequest="8"
                         BackgroundColor="#C2DFC2"
                         ProgressColor="#3A8A3A"
                         Margin="0,0,0,6"/>
			<Label Text="Activity Check-In"
                   HorizontalOptions="Center"
                   TextColor="#888888"
                   FontSize="13"
                   Margin="0,0,0,24"/>

			<!-- Mood Icon -->
			<Frame BackgroundColor="#FDE8E8"
                   CornerRadius="45"
                   WidthRequest="90"
                   HeightRequest="90"
                   Padding="0"
                   HorizontalOptions="Center"
                   HasShadow="False"
                   Margin="0,0,0,12">
				<Label x:Name="MoodEmoji"
                       Text="😰"
                       FontSize="38"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- Mood Title -->
			<Label x:Name="MoodTitle"
                   Text="You're Feeling Anxious"
                   TextColor="#1A1A1A"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>

			<Label Text="It's okay to feel this way. Grounding yourself can help calm your mind and ease the worry."
                   FontSize="14"
                   TextColor="#666666"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,24"/>

			<!-- Grounding Tip Card -->
			<Frame CornerRadius="14"
                   BackgroundColor="#FDE8E8"
                   BorderColor="#F0B0B0"
                   HasShadow="False"
                   Padding="16,14"
                   Margin="0,0,0,24">
				<HorizontalStackLayout Spacing="12">
					<Label Text="🧘" FontSize="22" VerticalOptions="Start" Margin="0,2,0,0"/>
					<Label VerticalOptions="Center" LineBreakMode="WordWrap" MaximumWidthRequest="250">
						<Label.FormattedText>
							<FormattedString>
								<Span Text="Grounding Activity: "
                                      FontAttributes="Bold"
                                      TextColor="#1A1A1A"
                                      FontSize="14"/>
								<Span Text="Use the 5-4-3-2-1 technique to anchor yourself to the present."
                                      TextColor="#555555"
                                      FontSize="14"/>
							</FormattedString>
						</Label.FormattedText>
					</Label>
				</HorizontalStackLayout>
			</Frame>

			<!-- Instruction -->
			<Label Text="Take a slow breath, then notice around you:"
                   TextColor="#444444"
                   FontSize="15"
                   FontAttributes="Bold"
                   Margin="0,0,0,16"/>

			<!-- WHAT IS MAKING YOU ANXIOUS -->
			<Label Text="WHAT IS MAKING YOU ANXIOUS?"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>
			<Frame CornerRadius="12"
                   BackgroundColor="#EAF5EA"
                   BorderColor="#C2DFC2"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
				<Entry x:Name="TriggerEntry"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- ONE THING IN YOUR CONTROL RIGHT NOW -->
			<Label Text="ONE THING IN YOUR CONTROL RIGHT NOW"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>
			<Frame CornerRadius="12"
                   BackgroundColor="#EAF5EA"
                   BorderColor="#C2DFC2"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,16">
				<Entry x:Name="ControlEntry"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- A CALMING THOUGHT OR PHRASE -->
			<Label Text="A CALMING THOUGHT OR PHRASE"
                   TextColor="#444444"
                   FontSize="12"
                   FontAttributes="Bold"
                   Margin="0,0,0,6"/>
			<Frame CornerRadius="12"
                   BackgroundColor="#EAF5EA"
                   BorderColor="#C2DFC2"
                   HasShadow="False"
                   Padding="12,0"
                   HeightRequest="54"
                   Margin="0,0,0,28">
				<Entry x:Name="CalmEntry"
                       TextColor="#1A1A1A"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"/>
			</Frame>

			<!-- Submit Button -->
			<Button Text="Submit Activity"
                    Clicked="OnSubmitActivityClicked"
                    BackgroundColor="#3A8A3A"
                    TextColor="White"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="17"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>
