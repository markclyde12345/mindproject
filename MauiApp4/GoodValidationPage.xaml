<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="project.GoodValidationPage"
             BackgroundColor="#F5FAF5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <VerticalStackLayout Padding="24,20,24,16" BackgroundColor="#F5FAF5" Spacing="8">

            <HorizontalStackLayout Spacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Mood Check-in"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"/>
                    <Label Text="Mood validation activity"
                           FontSize="12"
                           TextColor="#888888"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <ProgressBar Progress="1.0"
                         HeightRequest="8"
                         BackgroundColor="#949494"
                         ProgressColor="#1A1A1A"
                         Margin="0,4,0,0"/>

        </VerticalStackLayout>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,16,24,24" Spacing="20">

                <!-- Mood Circle -->
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                    <Frame BackgroundColor="#7CB342"
                           CornerRadius="45"
                           WidthRequest="90"
                           HeightRequest="90"
                           Padding="0"
                           HorizontalOptions="Center"
                           HasShadow="False">
                        <Label Text="🙂"
                               FontSize="38"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>

                    <Label Text="You're feeling Good!"
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"
                           FontSize="24"
                           HorizontalOptions="Center"/>

                    <Label Text="Let's amplify this positive feeling through gratitude practice."
                           TextColor="#666666"
                           FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>

                <!-- Gratitude Activity Card -->
                <Frame CornerRadius="14"
                       BackgroundColor="#D8EEFB"
                       BorderColor="#1560BD"
                       HasShadow="False"
                       Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Gratitude Activity:"
                               FontAttributes="Bold"
                               TextColor="#1560BD"
                               FontSize="14"/>
                        <Label Text="Expressing gratitude can boost your mood even further!"
                               TextColor="#1560BD"
                               FontSize="14"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Reflection Question -->
                <Label Text="What are you genuinely grateful for today?"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="#1A1A1A"
                       HorizontalTextAlignment="Center"/>

                <!-- Reflection Box -->
                <Frame CornerRadius="14"
                       BackgroundColor="White"
                       BorderColor="#E0E0E0"
                       HasShadow="False"
                       Padding="16,12">
                    <Editor x:Name="ReflectionEditor"
                            Placeholder="Additional reflection about how you're feeling..."
                            PlaceholderColor="#AAAAAA"
                            TextColor="#1A1A1A"
                            HeightRequest="130"
                            BackgroundColor="Transparent"/>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM BUTTON -->
        <VerticalStackLayout Grid.Row="2"
                             Padding="24,12,24,32"
                             BackgroundColor="#F5FAF5">
            <Button Text="Save Reflection"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#1560BD"
                    TextColor="White"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="17"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>